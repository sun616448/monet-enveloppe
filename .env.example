# Copy this to .env and fill in your key(s). .env is gitignored.

# OpenAI — keyframe generation (gpt-image-2). Required for live /api/enveloppe
# and the validate/ probes.
OPENAI_API_KEY=
# Org id for the key. Send it explicitly: without it the key uses its default
# org, which 401s ("invalid_organization") if that default is inaccessible.
OPENAI_ORG=

# Legacy probe keys (earlier model experiments; not used by the live path).
GEMINI_API_KEY=
BFL_API_KEY=
